{
  "name": "live-control-app",
  "private": true,
  "version": "0.1.0-beta.1",
  "description": "App para conectar TikTok LIVE con overlays, juegos y music request en una beta desktop.",
  "author": "SoraGFZ",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/index.js",
    "bridge:start": "node bridge/index.js",
    "tunnel": "node scripts/run-ngrok.mjs",
    "tunnel:auth": "node scripts/configure-ngrok.mjs",
    "tunnel:localtunnel": "node scripts/run-localtunnel.mjs",
    "tunnel:cloudflare": "node scripts/run-cloudflared.mjs",
    "public": "npm run build && concurrently -k \"npm:start\" \"npm:tunnel\"",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "express": "^5.2.1",
    "localtunnel": "^2.0.2",
    "multer": "^2.1.1",
    "rcon-client": "^4.2.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tiktok-live-connector": "^2.1.1-beta1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^37.0.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "io.soragfz.livecontrol.beta",
    "productName": "Live Control Beta",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "bridge/**/*",
      "electron/**/*",
      "src/live-control.js",
      "src/chaosmod.js",
      "public/event-art/**/*",
      "public/game-covers/**/*",
      "bridge-config.example.json",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**/*",
      "server/**/*",
      "bridge/**/*",
      "src/live-control.js",
      "src/chaosmod.js",
      "bridge-config.example.json",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Live Control Beta"
    }
  }
}
