PORT=5123
LIVE_CONTROL_STORAGE_DIR=

# Spotify (Developer Dashboard → https://developer.spotify.com/dashboard)
# Redirect URI debe coincidir con la que muestra Musica en la app, por ejemplo:
# http://127.0.0.1:5123/api/music/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Opcional: URL publica si usas tunel (ngrok / cloudflare)
# LIVE_CONTROL_PUBLIC_URL=https://tu-dominio.ejemplo